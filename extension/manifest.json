{
  "manifest_version": 3,
  "name": "V1-Helper",
  "version": "1.1.0",
  "description": "TrendAI V1-Helper: Chrome extension for booth demo session tracking with click capture, screenshots, and S3 upload.",
  "permissions": [
    "activeTab",
    "tabs",
    "storage"
  ],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "V1-Helper"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
