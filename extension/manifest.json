{
  "manifest_version": 3,
  "name": "CaseyApp Capture",
  "version": "2.0.0",
  "description": "CaseyApp: AI-powered demo capture for trade show booths. Captures screenshots and click data during live demos.",
  "permissions": [
    "activeTab",
    "tabs",
    "storage"
  ],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "CaseyApp Capture"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
