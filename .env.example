# BoothApp Environment Variables
# Copy to .env and fill in values before running.

# --- AWS ---
AWS_REGION=us-east-1
AWS_PROFILE=hackathon
# AWS_ACCESS_KEY_ID=         # Alternative to AWS_PROFILE
# AWS_SECRET_ACCESS_KEY=     # Alternative to AWS_PROFILE

# --- S3 ---
S3_BUCKET=boothapp-sessions-752266476357

# --- Analysis ---
ANALYSIS_MODEL=claude-sonnet-4-6
USE_BEDROCK=false
# RONE_AI_BASE_URL=https://api.anthropic.com
# RONE_AI_API_KEY=
# ANTHROPIC_API_KEY=

# --- Watcher ---
POLL_INTERVAL_SECONDS=30
HEALTH_PORT=8090

# --- Audio ---
# AUDIO_DEVICE=              # Force specific audio device (auto-detected if unset)
# SESSION_ID=                # Set by session orchestrator
# SE_SPEAKER_LABEL=spk_0    # Speaker label for the SE in transcripts
# OUTPUT_DIR=                # Local output dir (default: audio/output/<session-id>)

# --- Notifications ---
# WEBHOOK_URL=               # Teams/Slack webhook for session alerts
